# Supabase (sync cloud + auth) — OPCIONAL
# Si no se configuran, la app funciona en modo local (sin login, sin sync)
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Sentry (error tracking en producción) — OPCIONAL
# Solo se inicializa si la variable está definida y NO es un build de desarrollo.
# Crea un proyecto React en sentry.io y copia el DSN.
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxx@oXXXX.ingest.sentry.io/XXXX

# Plausible (analytics privacy-friendly) — OPCIONAL
# Solo se carga si está definido, en producción y si el usuario aceptó cookies.
# VITE_PLAUSIBLE_DOMAIN=tudominio.com
# Self-hosted: cambia el host por el tuyo. Por defecto usa plausible.io
# VITE_PLAUSIBLE_HOST=https://plausible.io

# Auditoría de usabilidad — credenciales para `npm run capture:screenshots`
# Cuenta de prueba con plan Pro y onboarding ya completado. Usar .env.local
# para que estos valores no se commiteen accidentalmente.
# TEST_USER_EMAIL=qa+gelatolab@example.com
# TEST_USER_PASSWORD=...
# BASE_URL=http://localhost:5173
